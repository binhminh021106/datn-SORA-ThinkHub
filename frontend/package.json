{
  "name": "frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "concurrently -c \"green.bold,blue.bold,magenta.bold,yellow.bold,cyan.bold,red.bold,white.bold\" -n \"VUE,QUEUE,CRON,GOLD,API,REVERB\" \"vite\" \"cd ../backend && php artisan queue:work\" \"cd ../backend && php artisan schedule:work\" \"cd ../backend && php artisan sora:crawl-gold\" \"cd ../backend && php artisan serve\" \"cd ../backend && php artisan reverb:start\"",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/"
  },
  "dependencies": {
    "@vueup/vue-quill": "^1.2.0",
    "axios": "^1.15.0",
    "bootstrap": "^5.3.8",
    "chart.js": "^4.5.1",
    "laravel-echo": "^2.3.4",
    "moment": "^2.30.1",
    "pinia": "^3.0.4",
    "pusher-js": "^8.5.0",
    "sweetalert2": "^11.26.22",
    "swiper": "^12.1.3",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/eslint-config-prettier": "^10.2.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "~10.6.2",
    "globals": "^16.5.0",
    "prettier": "3.7.4",
